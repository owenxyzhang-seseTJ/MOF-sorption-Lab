#!/bin/bash

set -u

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
PROJECT_DIR="$(cd "$SCRIPT_DIR/../../.." && pwd)"
if [[ ! -f "$PROJECT_DIR/launcher.py" ]]; then
  /usr/bin/osascript -e 'display dialog "没有找到 launcher.py，请把 MOF Sorption Lab.app 放在项目根目录中使用。" buttons {"好"} default button "好"'
  exit 1
fi

cd "$PROJECT_DIR" || exit 1

if command -v python3 >/dev/null 2>&1; then
  exec python3 "$PROJECT_DIR/launcher.py"
fi

if [[ -x "/Users/xiaoyuzhang/.cache/codex-runtimes/codex-primary-runtime/dependencies/python/bin/python3" ]]; then
  exec "/Users/xiaoyuzhang/.cache/codex-runtimes/codex-primary-runtime/dependencies/python/bin/python3" "$PROJECT_DIR/launcher.py"
fi

/usr/bin/osascript -e 'display dialog "没有找到可用的 Python 3。请先安装 Python 3，再重新启动 MOF Sorption Lab。" buttons {"好"} default button "好"'
exit 1
